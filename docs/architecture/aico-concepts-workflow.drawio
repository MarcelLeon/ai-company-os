        <mxCell id="human" value="Human Manager&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;sets project context,&lt;br&gt;assigns work by IM,&lt;br&gt;approves dangerous actions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#2563EB;fillColor=#DBEAFE;fontSize=13;fontColor=#1E3A8A;" vertex="1" parent="1">
