        <mxCell id="step1" value="1. Select Project Context&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;/projects&lt;br&gt;/project aico&lt;br&gt;/use project aico&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="210" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="2. Inspect Roles / Team&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;/roles /team /who&lt;br&gt;/assignment for debugging&lt;br&gt;status: idle / working / blocked&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="520" width="230" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="3. Send Work&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;ordinary message uses active project&lt;br&gt;explicit /claude or @reviewer still works&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#2563EB;fillColor=#DBEAFE;fontSize=13;fontColor=#1E3A8A;" vertex="1" parent="1">
          <mxGeometry x="600" y="520" width="230" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="4. Resolve Assignment&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;project context + route target&lt;br&gt;selects assignment seat&lt;br&gt;attaches provider session ref&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="520" width="230" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="step5" value="5. Build Prompt&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Agent base + role prompt&lt;br&gt;+ project brief + runtime context&lt;br&gt;+ user task&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="520" width="230" height="92" as="geometry"/>
        </mxCell>

        <mxCell id="core1" value="Orchestrator&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;command handling,&lt;br&gt;routing, streaming,&lt;br&gt;collaboration trigger detection&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#0F766E;fillColor=#CCFBF1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="1">
          <mxGeometry x="120" y="700" width="220" height="96" as="geometry"/>
        </mxCell>
        <mxCell id="core2" value="TaskBus + Governance&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;risk assessment&lt;br&gt;adapter capability gate&lt;br&gt;approval / rejection&lt;br&gt;task lifecycle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#0F766E;fillColor=#CCFBF1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="1">
          <mxGeometry x="390" y="690" width="230" height="116" as="geometry"/>
        </mxCell>
        <mxCell id="approval" value="Human Approval Gate&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;write_files / shell_exec / destructive&lt;br&gt;/approve or /reject&lt;br&gt;requester or listed reviewer only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#0F766E;fillColor=#CCFBF1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="1">
