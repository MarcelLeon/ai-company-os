        <mxCell id="localWork" value="Local Work Happens&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;repo inspection&lt;br&gt;file changes after approval&lt;br&gt;shell execution after approval&lt;br&gt;code review / analysis&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#6B7280;fillColor=#FFFFFF;fontSize=13;fontColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="1270" y="690" width="210" height="116" as="geometry"/>
        </mxCell>

        <mxCell id="collabFlow" value="Optional AI-to-AI Collaboration&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;implementer output contains line-start @reviewer request&lt;br&gt;Orchestrator consumes directive and creates reviewer child task through TaskBus&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#0F766E;fillColor=#CCFBF1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="1">
