        <mxCell id="agentCatalog" value="Agent Catalog&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;claude: Senior Implementer&lt;br&gt;codex: Code Reviewer&lt;br&gt;future OpenClaw / internal CLI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#0F766E;fillColor=#CCFBF1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="1">
