        <mxCell id="assignment1" value="Assignment / Seat&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;seat: aico-implementer&lt;br&gt;agent: claude&lt;br&gt;role: implementer&lt;br&gt;session: project-scoped&lt;br&gt;risk: approval_required&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
