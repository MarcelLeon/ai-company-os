        </mxCell>
        <mxCell id="project" value="Project&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;AI Company OS (aico)&lt;br&gt;repo path + north star&lt;br&gt;STATUS + journal + risks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#B45309;fillColor=#FEF3C7;fontSize=13;fontColor=#78350F;dashed=1;" vertex="1" parent="1">
